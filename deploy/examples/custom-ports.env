# Change the Longtail web port and keep it in the required firewall ports.

NET_TOOLS_SERVER_ENDPOINT=YOUR_SERVER_IP_OR_DOMAIN:51820

NET_TOOLS_BIND_PORT=8443

# Required ports are always allowed through the WireGuard-side firewall.
NET_TOOLS_FIREWALL_ENABLED=1
NET_TOOLS_FIREWALL_REQUIRED_INBOUND_PORTS=tcp/22,tcp/3389,udp/3389,tcp/8443
NET_TOOLS_FIREWALL_REQUIRED_OUTBOUND_PORTS=tcp/22,tcp/3389,udp/3389,tcp/8443
