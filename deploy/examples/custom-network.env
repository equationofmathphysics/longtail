# Use a different WireGuard subnet.
# Keep WG_SUBNET, WG_CIDR, SERVER_VPN_IP, and CLIENT_ALLOWED_IPS aligned.

NET_TOOLS_SERVER_ENDPOINT=YOUR_SERVER_IP_OR_DOMAIN:51820

NET_TOOLS_WG_SUBNET=10.77.0
NET_TOOLS_WG_CIDR=10.77.0.0/24
NET_TOOLS_SERVER_VPN_IP=10.77.0.1
NET_TOOLS_CLIENT_ALLOWED_IPS=10.77.0.0/24

NET_TOOLS_ADMIN_IPS=127.0.0.1,::1
NET_TOOLS_FIREWALL_ENABLED=1
